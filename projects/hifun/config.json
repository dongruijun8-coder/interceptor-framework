        "type": "none"
      },
      "output_mapping": {
        "id": "id",
        "name": "title",
        "amount": "score",
        "avatar_url": "avatar_url",
        "public_id": "public_id",
        "score_desc": "score_desc",
        "note": "Room-level ranking (top rooms by score). Not user-level."
      }
    },

