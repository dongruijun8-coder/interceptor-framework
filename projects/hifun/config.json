    "ranking": {
      "path": "/api/audioroom/v1/room/billboard",
      "method": "GET",
      "body": {
        "room_id": "{{room.id}}"
      },
      "pagination": {
        "type": "none",
        "note": "Returns full list per room. No pagination params needed."
      },
      "output_mapping": {
        "uid": "user_info.userid",
        "nick": "user_info.nickname",
        "gender": "user_info.gender",
        "avatar_url": "user_info.avatar_url",
        "level": "user_info.level",
        "public_id": "user_info.public_id",
        "age": "user_info.age",
        "lists": {
          "rich_day": { "response_list": "data.rich_day_billboard_list", "amount_field": "rich_value", "label": "富豪日榜" },
          "rich_week": { "response_list": "data.rich_week_billboard_list", "amount_field": "rich_value", "label": "富豪周榜" }
        },
        "note": "富豪榜 only. rich = gift senders. Response also contains heart lists (魅力榜) which are ignored."
      }
    },

    "ranking_v2": {
      "path": "/api/audioroom/v2/room/billboard",
      "method": "GET",
      "body": {
