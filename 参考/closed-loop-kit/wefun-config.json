{
  "meta": {
    "app_name": "wefun",
    "package": "com.pico.live",
    "version": "11.2.6.2381",
    "config_schema": "2.0",
    "updated": "2026-06-06T19:00:00",
    "status": {
      "room_list": "verified",
      "room_users": "verified",
      "send_message": "verified",
      "conversation_list": "verified",
      "ranking": "restricted"
    }
  },
  "server": {
    "base_url": "https://api.hiyaparty.com",
    "default_headers": {
      "content-type": "application/json; charset=utf-8",
      "user-agent": "Mozilla/5.0 (Linux; Android 12; 24031PN0DC) Pico/11.2.6.2381",
      "origin": "https://m.hiyaparty.com",
      "x-requested-with": "com.pico.live"
    }
  },
  "pipeline": {
    "encryption": "plaintext",
    "signing": {
      "plugin": "md5-h5-sign",
      "params": {
        "secret": "a3f7e4c2b9d8a1e5f6c7d8e9a0b1c2d3",
        "uid_field": "h_m",
        "ts_field": "ts",
        "sign_field": "h_sn",
        "ts_ms_field": "h_ts",
        "algorithm": "MD5",
        "pattern": "{uid}{secret}{ts}"
      },
      "_note": "H5 API only (ranking, account, pay). Native API (roomlist, room_users, IM) does NOT need sign — uses token in body."
    },
    "auth": {
      "plugin": "manual-token",
      "params": {
        "token_field": "token",
        "uid_field": "h_m",
        "device_id_field": "h_did"
      }
    },
    "messaging": {
      "plugin": "rest-json",
      "params": {
        "send_path": "/api/app/im/v1/conversation/send",
        "send_method": "POST",
        "conv_list_path": "/api/app/im/v1/conversation_list/list",
        "conv_history_path": "/api/app/im/v1/conversation/history"
      },
      "_note": "IM endpoints use /api/ prefix (migrated 2026-06-06). Native auth (token in body). sign param in URL is NOT validated — can omit."
    }
  },
  "endpoints": {
    "all_rooms": {
      "_source": "recommend_app",
      "_verified": true,
      "_note": "Home page live room list. Tabs: 男生(kind_id=100057), 女生(100039), 热门(100002). Native auth.",
      "path": "/recommend_app/app/v1/roomlist",
      "method": "POST",
      "body": {
        "tab_id": "{{tab_id}}",
        "kind_id": "{{kind_id}}",
        "sub_kind_id": "{{sub_kind_id}}",
        "offset": "{{offset}}",
        "direction": "{{direction}}",
        "h_m": "{{uid}}",
        "token": "{{token}}",
        "h_did": "{{device_id}}",
        "h_os": "32",
        "h_av": "11.2.6.2381",
        "h_app": "me-live",
        "h_ch": "office",
        "h_package": "com.pico.live"
      },
      "query_params": {},
      "pagination": {
        "type": "cursor_offset",
        "offset_field": "offset",
        "offset_sent": "data.offset",
        "size": 16,
        "stop_on": "empty_list",
        "_note": "offset is string from response. Empty string for first page."
      },
      "output_mapping": {
        "id": "room_id",
        "title": "title",
        "cover": "cover",
        "bg_cover": "bg_cover",
        "anchor_id": "mid",
        "room_score": "room_score",
        "live_on": "live_on",
        "category": "room_template_data.tag_name",
        "template": "room_template_data.template_name",
        "corner_mark": "room_corner_mark",
        "pk_info": "pk_info"
      }
    },
    "room_users": {
      "_source": "room_v2",
      "_verified": true,
      "_note": "Online users in a live room. Response: data.list[] with {mid, name}. Native auth.",
      "path": "/room_v2/app/room/room_online_user",
      "method": "POST",
      "body": {
        "room_id": "{{room_id}}",
        "h_m": "{{uid}}",
        "token": "{{token}}",
        "h_did": "{{device_id}}",
        "h_os": "32",
        "h_av": "11.2.6.2381",
        "h_app": "me-live",
        "h_ch": "office",
        "h_package": "com.pico.live"
      },
      "query_params": {},
      "output_mapping": {
        "uid": "mid",
        "name": "name"
      }
    },
    "room_kinds": {
      "_note": "Room category/tab configuration. Called once at app start.",
      "path": "/room_v2/app/room/kind/list",
      "method": "POST",
      "body": {},
      "query_params": {},
      "output_mapping": {
        "kind_id": "kind_id",
        "kind_name": "kind_name",
        "sub_kinds": "sub_kinds"
      }
    },
    "ranking": {
      "_verified": false,
      "_status": "restricted",
      "_note": "Account restricted. UI shows '无法看到榜单数据'. Returns data.list=null. H5 auth (h_sn).",
      "path": "/live/rank/common_rank",
      "method": "POST",
      "body": {
        "h_dt": 0,
        "h_os": "32",
        "h_model": "emulator_other",
        "h_did": "{{device_id}}",
        "h_sys": "{{device_id}}",
        "h_zone_offset": 28800,
        "h_zone_name": "Asia/Shanghai",
        "h_zone_abbreviation": "GMT+08:00",
        "h_carrier": "insertedno",
        "h_android_id": "{{device_id}}",
        "h_proxy": true,
        "h_vpn": false,
        "h_sjgy": false,
        "h_package": "com.pico.live",
        "h_area_region": "CS",
        "h_av": "11.2.6.2381",
        "h_version_code": 101861,
        "h_ch": "office",
        "h_app": "me-live",
        "h_language": "zh-CN",
        "h_test": 0,
        "h_ts": "{{h5_ts_ms}}",
        "h_appid": "68082pc",
        "h_m": "{{uid}}",
        "token": "{{token}}",
        "h_age": "{{age}}",
        "h_gender": "{{gender}}",
        "h_region_code": 86,
        "h_loc": {"h_lat": 0, "h_lon": 0, "city": "", "province": ""},
        "room_id": "{{room_id}}",
        "h_web_top": 3,
        "mid": "{{uid}}",
        "limit": 30,
        "offset": "{{offset}}",
        "rank_id": "{{data_source_key}}",
        "h_lv": "11.0.0"
      },
      "query_params": {
        "ts": "{{h5_ts}}",
        "h_sn": "{{h5_sn}}"
      },
      "pagination": {
        "type": "offset_limit",
        "size": 30,
        "stop_on": "empty_list"
      },
      "output_mapping": {
        "uid": "info.member.MemberSt.id",
        "nick": "info.member.MemberSt.name",
        "avatar": "info.member.MemberSt.avatar",
        "avatar_urls": "info.member.MemberSt.avatar_urls.aspect_low.urls[0]",
        "gender": "info.member.MemberSt.gender",
        "age": "info.member.MemberSt.age",
        "amount": "score"
      }
    },
    "send_message": {
      "_verified": true,
      "_note": "Send private message. API migrated to /api/ prefix + new nested body format (2026-06-06). sign in query string NOT validated — omit. conv_id = single_chat-{min}-{max}.",
      "_format_sniffed_from": "mitmproxy capture of app v11.2.6.2381",
      "path": "/api/app/im/v1/conversation/send",
      "method": "POST",
      "body": {
        "spec_conv": {
          "conv_type": "single_chat",
          "spec_conv_id": "{{to_uid}}"
        },
        "msg": {
          "content_type": "text",
          "content": {"text": "{{message}}"},
          "interact_type": "user_msg",
          "client_msg_id": "{{uuid_v4}}",
          "ct_millis": "{{ts_ms}}",
          "from_user_id": "{{uid_string}}",
          "to_user_id": "{{to_uid_string}}",
          "conv_type": "single_chat",
          "page_from": "we_msg_page",
          "room_id": 0,
          "conv_id": "{{conv_id}}",
          "biz_type": "chat"
        },
        "h_m": "{{uid}}",
        "h_did": "{{device_id}}",
        "h_ts": "{{ts_ms}}",
        "token": "{{token}}",
        "base_params": {
          "product_name": "w_project",
          "app_type": "android",
          "package_name": "com.pico.live",
          "version_name": "11.2.6.2381",
          "version_code": 101861,
          "channel": "office",
          "device_language": "zh",
          "user_id": "{{uid}}",
          "device_id": "{{device_id}}",
          "app_id": "68082pc"
        }
      },
      "query_params": {
        "sign": "{{sign_md5_optional}}",
        "_note": "sign parameter appears in app requests but not validated by server. Can be omitted."
      }
    },
    "conversation_list": {
      "_verified": true,
      "_note": "List existing conversations. API migrated to /api/ prefix (2026-06-06). Fallback user discovery.",
      "path": "/api/app/im/v1/conversation_list/list",
      "method": "POST",
      "body": {
        "display_group": "normal",
        "size": 50,
        "cursor": "",
        "h_m": "{{uid}}",
        "h_did": "{{device_id}}",
        "h_ts": "{{ts_ms}}",
        "token": "{{token}}",
        "base_params": {
          "product_name": "w_project",
          "app_type": "android",
          "package_name": "com.pico.live",
          "version_name": "11.2.6.2381",
          "version_code": 101861,
          "channel": "office",
          "device_language": "zh",
          "user_id": "{{uid}}",
          "device_id": "{{device_id}}",
          "app_id": "68082pc"
        }
      },
      "query_params": {
        "sign": "{{sign_md5_optional}}",
        "_note": "Not validated. Can omit."
      },
      "output_mapping": {
        "uid": "spec_conv_id",
        "conv_id": "conv_id",
        "last_msg": "last_msg.content",
        "last_time": "last_msg_time_mills"
      }
    },
    "conversation_history": {
      "_note": "Message history with a user. API migrated to /api/ prefix (2026-06-06).",
      "path": "/api/app/im/v1/conversation/history",
      "method": "POST",
      "body": {
        "h_m": "{{uid}}",
        "token": "{{token}}",
        "conv_id": "{{conv_id}}",
        "conv_type": "single_chat",
        "limit": 20,
        "offset": "{{offset}}"
      },
      "query_params": {
        "sign": "{{sign_md5_optional}}",
        "_note": "Not validated. Can omit."
      }
    }
  },
