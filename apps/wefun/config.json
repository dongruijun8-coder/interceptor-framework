  "_network": {
    "native_http": "api.hiyaparty.com — room list, room users. Auth: token in body, NO sign.",
    "im_http": "api.hiyaparty.com/api/* — IM (conversation send/list/history). Auth: token in body. sign in query NOT validated.",
    "h5_http": "api.hiyaparty.com — ranking, account, pay, noble, stat. Auth: h_sn=MD5(h_m+secret+ts) in query+body.",
    "ws_live": "ws-api.hiyaparty.com/ws — room events (enter type:900, member type:801). Auth: sign=MD5(uid+secret+ts) in query.",
    "ws_im_push": "ws-api.hiyaparty.com/app/rtm_connector/v1/connect — IM push. sign static per session.",
    "h5_ssr": "m.hiyaparty.com — Next.js SSR",
    "_migration_note": "IM endpoints moved from /app/im/* to /api/app/im/* circa 2026-06-06. Old paths return 404. Body format changed from flat to nested (spec_conv/msg/base_params)."
