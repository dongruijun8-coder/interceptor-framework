{
  "meta": {
    "app_name": "wefun",
    "package": "com.pico.live",
    "version": "11.2.6.2381",
    "config_schema": "2.0"
  },
  "server": {
    "base_url": "https://api.hiyaparty.com",
    "default_headers": {
      "content-type": "application/json; charset=utf-8",
      "user-agent": "Mozilla/5.0 (Linux; Android 12; 24031PN0DC) Pico/11.2.6.2381",
      "origin": "https://m.hiyaparty.com",
      "x-requested-with": "com.pico.live"
    }
  },
  "pipeline": {
    "encryption": "plaintext",
    "signing": {
      "plugin": "md5-h5-sign",
      "params": {
        "secret": "a3f7e4c2b9d8a1e5f6c7d8e9a0b1c2d3",
        "uid_field": "h_m",
        "ts_field": "ts",
        "sign_field": "h_sn",
        "ts_ms_field": "h_ts",
        "algorithm": "MD5",
        "pattern": "{uid}{secret}{ts}"
      }
    },
    "auth": {
      "plugin": "manual-token",
      "params": {
        "token_field": "token",
        "uid_field": "h_m"
      }
    },
    "messaging": {
      "plugin": "rest-json",
      "params": {
        "send_path": "/api/app/im/v1/conversation/send",
        "send_method": "POST",
        "conv_list_path": "/api/app/im/v1/conversation_list/list",
        "conv_history_path": "/api/app/im/v1/conversation/history"
      }
    }
  },
  "endpoints": {
    "all_rooms": {
      "transport": "ws",
      "ws": {
        "script": "hook_ws_rooms.js",
        "method": "getRooms"
      },
      "output_mapping": {
        "id": "id",
        "name": "name",
        "cover": "cover",
        "member_cnt": "member_cnt"
      }
    },
    "ranking": {
      "path": "/live/rank/common_rank",
      "method": "POST",
      "body": {
        "h_dt": 0,
        "h_os": "32",
        "h_model": "emulator_other",
        "h_did": "{{device_id}}",
        "h_sys": "{{device_id}}",
        "h_zone_offset": 28800,
        "h_zone_name": "Asia/Shanghai",
        "h_zone_abbreviation": "GMT+08:00",
        "h_carrier": "insertedno",
        "h_android_id": "{{device_id}}",
        "h_proxy": true,
        "h_vpn": false,
        "h_sjgy": false,
        "h_package": "com.pico.live",
        "h_area_region": "CS",
        "h_av": "11.2.6.2381",
        "h_version_code": 101861,
        "h_ch": "office",
        "h_app": "me-live",
        "h_language": "zh-CN",
        "h_test": 0,
        "h_appid": "68082pc",
        "h_m": "{{uid}}",
        "token": "{{token}}",
        "h_age": "{{age}}",
        "h_gender": "{{gender}}",
        "h_region_code": 86,
        "h_loc": {"h_lat": 0, "h_lon": 0, "city": "", "province": ""},
        "room_id": "{{room.id}}",
        "h_web_top": 3,
        "mid": "{{uid}}",
        "limit": 30,
        "offset": "{{offset}}",
        "rank_id": "{{data_source_key}}",
        "h_lv": "11.0.0"
      },
      "pagination": {
        "type": "offset_limit",
        "size": 30,
        "stop_on": "empty_list"
      },
      "output_mapping": {
        "uid": "info.member.MemberSt.id",
        "nick": "info.member.MemberSt.name",
        "avatar": "info.member.MemberSt.avatar",
        "avatar_urls": "info.member.MemberSt.avatar_urls.aspect_low.urls[0]",
        "gender": "info.member.MemberSt.gender",
        "age": "info.member.MemberSt.age",
        "amount": "score"
      }
    }
  },
  "runtime_config": {
    "settings": { "send_interval": 5 },
    "data_sources": {
      "贡献榜": "2001",
      "守护榜": "2002",
      "贵族榜": "2003",
      "魅力榜": "2004"
    },
    "periods": {
      "日榜": "day",
      "周榜": "week",
      "总榜": "total"
    },
    "genders": {
      "全部": null,
      "女": 0,
      "男": 1,
      "其他": 2
    },
    "templates": ["{nick} 你好~", "{nick} 在吗？"]
  },
  "_network": {
    "native_http": "api.hiyaparty.com — IM (conversation list/history/send/read)",
    "h5_http": "api.hiyaparty.com — H5 API (ranking, account, pay, noble, stat)",
    "ws_live": "ws-api.hiyaparty.com/ws — room events (enter, members, gifts)",
    "ws_im_push": "ws-api.hiyaparty.com/app/rtm_connector/v1/connect — IM push",
    "h5_ssr": "m.hiyaparty.com — Next.js SSR"
  }
}
