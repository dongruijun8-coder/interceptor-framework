        "h_m": "{{uid}}",
        "token": "{{token}}",
        "h_did": "{{device_id}}",
        "h_os": "32",
        "h_av": "11.2.6.2381",
        "h_app": "me-live",
        "h_ch": "office",
        "h_package": "com.pico.live"
      },
      "output_mapping": {
        "uid": "mid",
        "nick": "name"
      }
    },
    "room_kinds": {
      "_note": "Room category/tab configuration. Called once at app start.",
      "path": "/room_v2/app/room/kind/list",
      "method": "POST",
      "body": {},
      "query_params": {},
      "output_mapping": {
        "kind_id": "kind_id",
        "kind_name": "kind_name",
        "sub_kinds": "sub_kinds"
      }
    },
    "ranking": {
      "path": "/room_v2/app/room/room_online_user",
      "method": "POST",
      "body": {
        "room_id": "{{room.id}}",
        "h_m": "{{uid}}",
        "token": "{{token}}",
        "h_did": "{{device_id}}",
        "h_os": "32",
        "h_av": "11.2.6.2381",
        "h_app": "me-live",
        "h_ch": "office",
        "h_package": "com.pico.live"
      },
      "response_path": "data.list",
      "output_mapping": {
        "uid": "mid",
        "nick": "name",
        "gender": null
