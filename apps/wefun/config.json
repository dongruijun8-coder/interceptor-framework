  "endpoints": {
    "all_rooms": {
      "path": "/recommend_app/app/v1/roomlist",
      "method": "POST",
      "body": {
        "tab_id": 2,
        "kind_id": 100002,
        "offset": "",
        "direction": "refresh",
        "h_m": "{{uid}}",
        "token": "{{token}}",
        "h_did": "{{device_id}}",
        "h_os": "32",
        "h_av": "11.2.6.2381",
        "h_app": "me-live",
        "h_ch": "office",
        "h_package": "com.pico.live"
      },
      "response_path": "data.list",
      "pagination": {
        "type": "cursor_offset",
        "offset_field": "offset",
        "offset_sent": "data.offset",
        "size": 16,
        "stop_on": "empty_list"
      },
      "output_mapping": {
        "id": "room_id",
        "name": "title",
        "cover": "cover"
      }
    },
    "ranking": {
      "path": "/room_v2/app/room/room_online_user",
