  "_closed_loop": {
    "step1": "POST /recommend_app/app/v1/roomlist — pick room_id",
    "step2": "POST /room_v2/app/room/room_online_user — pick user mid",
    "step3": "POST /api/app/im/v1/conversation/send — conv_id = single_chat-{min}-{max}",
    "status": "all 3 endpoints verified 2026-06-06 19:00",
